{
  "name": "static-file-server",
  "version": "1.0.0",
  "description": "Simple static file server for Cloudflare Workers",
  "main": "worker.js",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env dev",
    "deploy:prod": "wrangler deploy --env production",
    "publish": "wrangler deploy --env production",
    "tail": "wrangler tail",
    "logs": "wrangler tail --format pretty",
    "secret": "wrangler secret put ACCESS_KEY",
    "whoami": "wrangler whoami",
    "pages:dev": "wrangler pages dev resource",
    "pages:deploy": "wrangler pages deploy resource"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
